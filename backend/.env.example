# =============================================================
# LinguaCompanion Backend — Environment Variables
# Copy to .env and fill in your values
# =============================================================

# --- App ---
APP_NAME=LinguaCompanion API
DEBUG=false
VERSION=0.2.0

# --- Database ---
DATABASE_URL=sqlite:///./dev.db
# Production: DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Redis ---
REDIS_URL=redis://localhost:6380/0

# --- LLM Model Router (OpenRouter) ---
OPENROUTER_API_KEY=
# Legacy fallback (used by agents not yet migrated to per-task models)
LLM_MODEL=openrouter/deepseek/deepseek-v3.2
# Per-task model overrides
MODEL_COMPANION=openrouter/deepseek/deepseek-v3.2
MODEL_RECONSTRUCTION=openrouter/deepseek/deepseek-v3.2
MODEL_VARIANTS=openrouter/deepseek/deepseek-v3.2
MODEL_TRANSLATION=openrouter/qwen/qwen3-235b-a22b-2507
MODEL_EXTRACTION=openrouter/qwen/qwen3-235b-a22b-2507
MODEL_ONBOARDING=openrouter/google/gemma-4-31b-it:free
MODEL_TOPIC_DISCOVERY=openrouter/qwen/qwen3-235b-a22b-2507

# --- STT ---
DEEPGRAM_API_KEY=
GROQ_API_KEY=
STT_PROVIDER=deepgram
WHISPER_MODEL=whisper-large-v3-turbo

# --- TTS Fallback Chain ---
# ElevenLabs keys, comma-separated for rotation
ELEVENLABS_API_KEYS=
# AWS Polly (TTS fallback)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Embeddings ---
GEMINI_API_KEY=
GOOGLE_EMBEDDINGS_MODEL=text-embedding-004

# --- Auth ---
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
