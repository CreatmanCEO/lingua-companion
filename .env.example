# =============================================================
# LinguaCompanion AI — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =============================================================

# --- AI: LLM + STT (Groq) ---
# Get at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- AI: Gemini (Google) ---
# Get at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- AI: Pronunciation (Azure Speech) ---
# Get at: https://portal.azure.com → Cognitive Services → Speech
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# --- Database (Supabase) ---
# Get at: https://supabase.com → Project Settings → Database
DATABASE_URL=postgresql://postgres:password@db:5432/lingua_companion
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Cache (Redis) ---
# Local Docker: redis://redis:6379
# Upstash free tier: https://upstash.com
REDIS_URL=redis://redis:6379

# --- Auth (NextAuth.js) ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for login)
# Get at: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# --- Topic Discovery ---
# Reddit API (optional, for topic discovery)
# Get at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=LinguaCompanion/1.0

# --- App Config ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- File Storage ---
# Local development: files stored in ./uploads
# Production: Supabase Storage or S3-compatible
STORAGE_PROVIDER=local
# STORAGE_BUCKET=lingua-companion-audio
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# --- Coolify (production only) ---
# COOLIFY_WEBHOOK_URL=https://coolify.yourdomain.com/api/v1/deploy/webhook?uuid=xxx
